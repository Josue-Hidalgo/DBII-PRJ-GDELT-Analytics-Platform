# ─────────────────────────────────────────────────────────────────
# GDELT Pipeline — Variables de Entorno
# Copia este archivo a .env y ajusta los valores para tu entorno.
# NUNCA subas el archivo .env real al repositorio.
# ─────────────────────────────────────────────────────────────────

# ─── MongoDB ──────────────────────────────────────────────────────
MONGO_USER=gdelt_admin
MONGO_PASSWORD=changeme_strong_password
MONGO_DB=gdelt
MONGO_PORT=27017

# ─── Loader ───────────────────────────────────────────────────────
LOADER_INTERVAL_MINUTES=15        # Frecuencia de descarga de GDELT
RAW_RETENTION_HOURS=24            # Horas que se guardan los RAW antes de borrar
PARQUET_OUTPUT_DIR=/data/parquet  # Directorio de salida de Parquet (dentro del contenedor)
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR

# ─── Spark ────────────────────────────────────────────────────────
SPARK_MASTER_PORT=7077
SPARK_MASTER_WEBUI_PORT=8080
SPARK_WORKER_CORES=2              # CPUs por worker
SPARK_WORKER_MEMORY=2g            # RAM por worker (ej. 2g, 4g)
SPARK_WORKER_REPLICAS=2           # Número de workers

# ─── HDFS ─────────────────────────────────────────────────────────
HDFS_NAMENODE_UI_PORT=9870

# ─── Dashboard ────────────────────────────────────────────────────
DASHBOARD_PORT=5000
DASHBOARD_SECRET_KEY=change_this_secret_key_in_production

# ─── Airflow (opcional) ───────────────────────────────────────────
AIRFLOW_PORT=8081
